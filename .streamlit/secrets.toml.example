# Streamlit Cloud Secrets 配置模板
# 复制此文件内容到 Streamlit Cloud → Settings → Secrets
# 或在本地创建 .streamlit/secrets.toml（已在 .gitignore 中排除）

[database]
# 数据库类型：sqlite（云端推荐）或 mysql（需外部数据库）
type = "sqlite"

# 如使用 MySQL，填写以下配置：
# host = "your-mysql-host.com"
# port = 3306
# user = "your_user"
# password = "your_password"
# database = "textbook_fee"

[admin]
# 管理员登录密码（bcrypt hash，默认 admin123）
# 可留空使用系统默认值
password_hash = ""
